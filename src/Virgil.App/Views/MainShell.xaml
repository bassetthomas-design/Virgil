<Window x:Class="Virgil.App.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Virgil.App.Views"
        mc:Ignorable="d"
        Title="Virgil" Height="720" Width="1120" Background="#0B0B0B">
    <DockPanel>
        <!-- Top toolbar (no code-behind handlers to keep build green) -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Height="36" Background="#141414">
                <TextBlock Text="VIRGIL" Foreground="#00FFC8" FontWeight="Bold" Margin="4,0" VerticalAlignment="Center"/>
                <Separator/>
                <Button Margin="8,0" Padding="10,4">Paramètres</Button>
                <Button Margin="8,0" Padding="10,4">Mini HUD</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Main area: left actions | center avatar | right chat -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Actions panel (placeholder) -->
            <Border Grid.Column="0" Background="#111" BorderBrush="#222" BorderThickness="0,0,1,0">
                <StackPanel Margin="16">
                    <TextBlock Text="Actions" Foreground="#DDD" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="(à câbler)" Foreground="#888"/>
                </StackPanel>
            </Border>

            <!-- Avatar center -->
            <Grid Grid.Column="1">
                <views:AvatarView HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Chat panel (placeholder) -->
            <Border Grid.Column="2" Background="#101010" BorderBrush="#222" BorderThickness="1,0,0,0">
                <StackPanel Margin="16">
                    <TextBlock Text="Chat" Foreground="#DDD" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="(à câbler)" Foreground="#888"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar bottom -->
        <StatusBar DockPanel.Dock="Bottom" Background="#141414" Foreground="#AAA">
            <StatusBarItem Content="Prêt"/>
        </StatusBar>
    </DockPanel>
</Window>
