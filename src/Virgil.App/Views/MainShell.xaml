<Window x:Class="Virgil.App.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Virgil.App.Views"
        Title="Virgil" Width="1100" Height="720" Background="#0B0B0B">
    <DockPanel LastChildFill="True">
        <!-- Top toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Padding="10,4" Margin="0,0,6,0" Click="OnHudToggled">Mini HUD</Button>
                <Button Padding="10,4" Margin="0,0,6,0" Click="OnOpenSettings">Paramètres</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Main layout -->
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Avatar + MiniHUD placeholder -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <views:AvatarView Width="240" Height="240"/>
                <!-- MiniHUD placeholder (bars) -->
                <StackPanel>
                    <ProgressBar Height="6" Minimum="0" Maximum="100" Value="22"/>
                    <ProgressBar Height="6" Minimum="0" Maximum="100" Value="41" Margin="0,6,0,0"/>
                    <ProgressBar Height="6" Minimum="0" Maximum="100" Value="18" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Center: Chat placeholder -->
            <Border Grid.Column="1" CornerRadius="8" BorderBrush="#1E1E1E" BorderThickness="1" Background="#111">
                <TextBlock Text="Chat en préparation…" Foreground="#AAA" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- Right: Actions -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="8">
                <TextBlock Text="Actions rapides" Foreground="#DDD" FontWeight="Bold" Margin="0,0,0,8"/>
                <Button Padding="10" Content="Surveillance ON/OFF"/>
                <Button Padding="10" Content="Maintenance complète"/>
                <Button Padding="10" Content="Nettoyage intelligent"/>
                <Button Padding="10" Content="Nettoyer navigateurs"/>
                <Button Padding="10" Content="Tout mettre à jour"/>
                <Button Padding="10" Content="Defender (MAJ + Scan)"/>
                <Button Padding="10" Content="Ouvrir configuration" Click="OnOpenSettings"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
