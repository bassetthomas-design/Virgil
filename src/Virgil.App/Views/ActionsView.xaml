<UserControl x:Class="Virgil.App.Views.ActionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Maintenance rapide -->
            <TextBlock Text="Maintenance rapide"
                       Foreground="#DDD"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Scan système express"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="quick_scan"/>
                <Button Content="Nettoyage rapide"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="quick_clean"/>
                <Button Content="Nettoyage navigateur (léger)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="browser_soft_clean"/>
                <Button Content="Libérer la RAM (soft)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="ram_soft_free"/>
            </StackPanel>

            <!-- Maintenance avancée -->
            <TextBlock Text="Maintenance avancée"
                       Foreground="#DDD"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Nettoyage disque avancé"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="deep_disk_clean"/>
                <Button Content="Vérification disque"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="disk_check"/>
                <Button Content="Vérification intégrité système"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="system_integrity"/>
                <Button Content="Nettoyage navigateur (profond)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="browser_deep_clean"/>
            </StackPanel>

            <!-- Réseau & Internet -->
            <TextBlock Text="Réseau & Internet"
                       Foreground="#DDD"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Diagnostic réseau rapide"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="network_diag"/>
                <Button Content="Réinitialisation réseau (soft)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="network_soft_reset"/>
                <Button Content="Réinitialisation réseau (avancée)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="network_hard_reset"/>
                <Button Content="Test latence / stabilité"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="network_latency_test"/>
            </StackPanel>

            <!-- Performances & Gaming -->
            <TextBlock Text="Performances & Gaming"
                       Foreground="#DDD"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Activer mode Performance / Gaming"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="perf_mode_on"/>
                <Button Content="Revenir en mode normal"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="perf_mode_off"/>
                <Button Content="Analyser les programmes au démarrage"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="startup_analyze"/>
                <Button Content="Fermer la session gaming (jeux + overlays)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="gaming_kill_session"/>
            </StackPanel>

            <!-- Mises à jour -->
            <TextBlock Text="Mises à jour"
                       Foreground="#DDD"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Mettre à jour les logiciels installés"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="apps_update_all"/>
                <Button Content="Lancer la mise à jour Windows"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="windows_update"/>
                <Button Content="Vérifier les drivers graphiques"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="gpu_driver_check"/>
            </StackPanel>

            <!-- Mode RAMBO -->
            <TextBlock Text="Mode RAMBO"
                       Foreground="#FF4D4D"
                       FontSize="14"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Mode RAMBO (réparer l'explorateur et le cache d'icônes)"
                        Margin="0,0,0,4"
                        ToolTip="Redémarre l'explorateur Windows et nettoie les caches d'icônes. L'écran peut clignoter."
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="rambo_repair"/>
            </StackPanel>

            <!-- Virgil / Interface -->
            <TextBlock Text="Virgil & interface"
                       Foreground="#DDD"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,12">
                <Button Content="Effet Thanos (vider le chat)"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="chat_thanos"/>
                <Button Content="Recharger la configuration"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="app_reload_settings"/>
                <Button Content="Re-scan système / monitoring"
                        Margin="0,0,0,4"
                        Command="{Binding ExecuteActionCommand}"
                        CommandParameter="monitoring_rescan"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
